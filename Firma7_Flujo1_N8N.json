    {
      "id": "f7-005",
      "name": "🔴 Preparar Datos Descartado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        320
      ],
      "parameters": {
        "jsCode": "// RAMA B — lead_descartado (no califica por filtro automático)\nconst d = $input.first().json;\n\nlet motivo = 'Motivo no determinado';\nif (d.ingresos === 'Menor a 150 mil pesos') {\n  motivo = 'Ingresos insuficientes (< $150k MXN/mes)';\n} else if (d.antiguedad === 'Menor a 6 meses') {\n  motivo = 'Antigüedad insuficiente (< 6 meses)';\n} else if (d.constitucion === 'Persona Física con Actividad Empresarial' && d.buroPF === 'Malo') {\n  motivo = 'Buró malo — Persona Física';\n} else if (d.buroPMEmpresa === 'Malo') {\n  motivo = 'Buró malo — Empresa';\n} else if (d.buroPMAccionista === 'Malo') {\n  motivo = 'Buró malo — Accionista principal';\n}\n\nconst clientType = d.constitucion === 'Persona Moral' ? 'persona_moral' : 'persona_fisica';\nconst fecha = new Date(d.timestamp).toLocaleString('es-MX', {timeZone: 'America/Mexico_City'});\n\nconst waMsg =\n  '🔴 *LEAD EN ESPERA — FIRMA 7*\\n\\n' +\n  '• Nombre: ' + d.nombreCompleto + '\\n' +\n  '• WhatsApp: ' + d.numero + '\\n' +\n  '• Correo: ' + d.correo + '\\n' +\n  '• Motivo: ' + motivo + '\\n\\n' +\n  'Lead redirigido a espera.html automáticamente.\\n' +\n  '⏰ ' + fecha;\n\nreturn [{\n  json: {\n    supabase_body: JSON.stringify({\n      name: d.nombreCompleto || '',\n      email: d.correo || '',\n      phone: d.numero || '',\n      source: 'formulario_web',\n      client_type: clientType,\n      tags: ['descartado', 'filtro_automatico'],\n      priority: 1,\n      is_archived: false,\n      internal_notes: 'DESCARTADO: ' + motivo\n    }),\n    wa_body: JSON.stringify({\n      messaging_product: 'whatsapp',\n      to: '525525069817',\n      type: 'text',\n      text: { body: waMsg }\n    })\n  }\n}];"
      }
    },
