        720,
        100
      ],
      "parameters": {
        "jsCode": "// RAMA A — lead_capturado (solo paso 0: nombre, teléfono, correo)\nconst d = $input.first().json;\nconst fecha = new Date(d.timestamp).toLocaleString('es-MX', {timeZone: 'America/Mexico_City'});\n\nreturn [{\n  json: {\n    supabase_body: JSON.stringify({\n      name: d.nombreCompleto || '',\n      email: d.correo || '',\n      phone: d.numero || '',\n      source: 'formulario_web',\n      tags: ['capturado_incompleto'],\n      priority: 1,\n      internal_notes: 'Lead capturado en paso 0. No completó el formulario. Fecha: ' + fecha\n    })\n  }\n}];"
      }
    },
    {
      "id": "f7-004",
