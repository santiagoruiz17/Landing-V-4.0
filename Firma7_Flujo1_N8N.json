      "parameters": {
        "jsCode": "// RAMA C — lead_calificado (formulario completo, alta prioridad)\nconst d = $input.first().json;\n\nconst clientType = d.constitucion === 'Persona Moral' ? 'persona_moral' : 'persona_fisica';\nconst monto = parseInt((d.monto || '0').replace(/,/g, ''), 10);\nconst montoFmt = monto.toLocaleString('es-MX');\nconst fecha = new Date(d.timestamp).toLocaleString('es-MX', {timeZone: 'America/Mexico_City'});\n\nconst tags = ['calificado_web'];\nif (clientType === 'persona_moral') tags.push('persona_moral'); else tags.push('pfae');\nif (d.garantia === 'Sí') tags.push('con_garantia'); else tags.push('sin_garantia');\n\nlet buroInfo = '';\nif (d.constitucion === 'Persona Moral') {\n  buroInfo = '• Buró empresa: ' + (d.buroPMEmpresa || '—') + '\\n• Buró accionista: ' + (d.buroPMAccionista || '—') + '\\n';\n} else {\n  buroInfo = '• Buró: ' + (d.buroPF || '—') + '\\n';\n}\n\nconst notas = 'Ingresos: ' + d.ingresos +\n  ' | Antigüedad: ' + d.antiguedad +\n  ' | Cargo: ' + (d.cargo || '—') +\n  ' | Destino: ' + d.destino +\n  ' | Garantía: ' + d.garantia;\n\nconst waMsg =\n  '🟢 *LEAD CALIFICADO — FIRMA 7*\\n\\n' +\n  '📋 *SOLICITUD RECIBIDA*\\n' +\n  '• Nombre: ' + d.nombreCompleto + '\\n' +\n  '• WhatsApp: ' + d.numero + '\\n' +\n  '• Correo: ' + d.correo + '\\n' +\n  '• RFC: ' + (d.rfc || '—') + '\\n' +\n  '• Cargo: ' + (d.cargo || '—') + '\\n\\n' +\n  '🏢 *EMPRESA*\\n' +\n  '• Constitución: ' + d.constitucion + '\\n' +\n  '• Antigüedad: ' + d.antiguedad + '\\n' +\n  '• Ingresos: ' + d.ingresos + '\\n' +\n  buroInfo + '\\n' +\n  '💰 *CRÉDITO SOLICITADO*\\n' +\n  '• Monto: $' + montoFmt + ' MXN\\n' +\n  '• Destino: ' + d.destino + '\\n' +\n  '• Garantía: ' + d.garantia + '\\n\\n' +\n  '⏰ ' + fecha + '\\n\\n' +\n  '_Contáctar en las próximas 2 horas para maximizar conversión._';\n\nreturn [{\n  json: {\n    supabase_body: JSON.stringify({\n      name: d.nombreCompleto || '',\n      email: d.correo || '',\n      phone: d.numero || '',\n      rfc: d.rfc || null,\n      source: 'formulario_web',\n      client_type: clientType,\n      credit_amount_requested: monto,\n      tags: tags,\n      priority: 2,\n      is_archived: false,\n      internal_notes: notas\n    }),\n    wa_body: JSON.stringify({\n      messaging_product: 'whatsapp',\n      to: '525525069817',\n      type: 'text',\n      text: { body: waMsg }\n    })\n  }\n}];"
      }
