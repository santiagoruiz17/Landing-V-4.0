      "typeVersion": 4.2,
      "position": [
        960,
        100
      ],
      "parameters": {
        "method": "POST",
        "url": "https://xhlssiypzeakrqrzhirx.supabase.co/rest/v1/clients",
        "sendHeaders": true,
        "headerParameters": {
